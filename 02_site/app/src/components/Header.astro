---
const nav = [
  { href: "/posts", label: "Posts" },
  { href: "/about", label: "About" },
];
const pathname = Astro.url.pathname;
---

<header class="border-b border-hairline">
  <div class="mx-auto max-w-5xl px-6 sm:px-8 py-5 flex items-center justify-between gap-4">
    <div class="flex flex-col gap-0.5">
      <a href="/" class="font-medium tracking-tight no-underline">
        ◐ Parallax Playbook
      </a>
      <span class="hidden min-[520px]:block text-small text-muted">
        Quantum, consciousness &amp; mathematics — the surprising stuff, explained simply.
      </span>
    </div>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-6 text-sm">
        {nav.map((item) => {
          const isActive = pathname === item.href || pathname.startsWith(item.href + "/");
          return (
            <li>
              <a
                href={item.href}
                class={isActive ? "text-foreground" : "text-muted hover:text-foreground"}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>
