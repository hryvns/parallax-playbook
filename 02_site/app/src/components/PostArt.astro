---
/**
 * PostArt — the site's house art style ("Geometric Orbit").
 * Generates a deterministic SVG per post: seeded by the post id (so each post
 * has a stable, unique graphic) and colored by topic. Free, instant,
 * copyright-safe, and consistent site-wide. Fills its container (slice).
 */
interface Props {
  topic: "quantum" | "consciousness" | "mathematics";
  seed: string;
  class?: string;
}

const { topic, seed, class: className = "" } = Astro.props;

const COLOR: Record<string, string> = {
  quantum: "#7DD3FC",
  consciousness: "#C4A7F5",
  mathematics: "#F5B544",
};
const color = COLOR[topic] ?? "#A78BFA";

function hash(str: string): number {
  let h = 2166136261;
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function rng(s: number) {
  return function () {
    s |= 0; s = (s + 0x6d2b79f5) | 0;
    let t = Math.imul(s ^ (s >>> 15), 1 | s);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const W = 480, H = 270;
const uid = "a" + hash(seed).toString(36);
const r = rng(hash(seed));

const cx = W * (0.40 + r() * 0.20);
const cy = H * (0.40 + r() * 0.20);

let body = "";

// concentric rings
const rings = 3 + Math.floor(r() * 3); // 3–5
let outer = 0;
for (let i = 0; i < rings; i++) {
  const rad = 20 + i * 24 + r() * 6;
  outer = Math.max(outer, rad);
  const op = Math.max(0.12, 0.55 - i * 0.09);
  body += `<circle cx="${cx.toFixed(1)}" cy="${cy.toFixed(1)}" r="${rad.toFixed(1)}" fill="none" stroke="${color}" stroke-opacity="${op.toFixed(2)}" stroke-width="1"/>`;
}

// diameter line through the centre at a random angle
const a0 = r() * Math.PI;
const lx = Math.cos(a0) * outer, ly = Math.sin(a0) * outer;
body += `<line x1="${(cx - lx).toFixed(1)}" y1="${(cy - ly).toFixed(1)}" x2="${(cx + lx).toFixed(1)}" y2="${(cy + ly).toFixed(1)}" stroke="${color}" stroke-opacity="0.22" stroke-width="0.7"/>`;

// a partial arc on the outer ring for asymmetry
const arcStart = r() * Math.PI * 2;
const arcLen = Math.PI * (0.5 + r() * 0.7);
const ax1 = cx + Math.cos(arcStart) * outer, ay1 = cy + Math.sin(arcStart) * outer;
const ax2 = cx + Math.cos(arcStart + arcLen) * outer, ay2 = cy + Math.sin(arcStart + arcLen) * outer;
const largeArc = arcLen > Math.PI ? 1 : 0;
body += `<path d="M ${ax1.toFixed(1)} ${ay1.toFixed(1)} A ${outer.toFixed(1)} ${outer.toFixed(1)} 0 ${largeArc} 1 ${ax2.toFixed(1)} ${ay2.toFixed(1)}" fill="none" stroke="${color}" stroke-opacity="0.7" stroke-width="1.6"/>`;

// the bold accent dot, sitting on the outer ring with a soft halo
const ang = r() * Math.PI * 2;
const dx = cx + Math.cos(ang) * outer, dy = cy + Math.sin(ang) * outer;
body += `<circle cx="${dx.toFixed(1)}" cy="${dy.toFixed(1)}" r="15" fill="${color}" opacity="0.16"/>`;
body += `<circle cx="${dx.toFixed(1)}" cy="${dy.toFixed(1)}" r="5.5" fill="${color}"/>`;

// a couple of tiny satellite dots on inner rings
for (let k = 0; k < 2; k++) {
  const ringRad = 20 + Math.floor(r() * rings) * 24;
  const sa = r() * Math.PI * 2;
  body += `<circle cx="${(cx + Math.cos(sa) * ringRad).toFixed(1)}" cy="${(cy + Math.sin(sa) * ringRad).toFixed(1)}" r="2.2" fill="${color}" opacity="0.8"/>`;
}

const svg = `<svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
  <defs><radialGradient id="g${uid}" cx="28%" cy="22%" r="95%">
    <stop offset="0%" stop-color="${color}" stop-opacity="0.20"/>
    <stop offset="55%" stop-color="${color}" stop-opacity="0"/>
  </radialGradient></defs>
  <rect width="${W}" height="${H}" fill="#0b0e14"/>
  <rect width="${W}" height="${H}" fill="url(#g${uid})"/>
  ${body}
</svg>`;
---

<div class:list={["post-art", className]} set:html={svg} aria-hidden="true"></div>

<style>
  .post-art { display: block; line-height: 0; }
  .post-art :global(svg) { display: block; width: 100%; height: 100%; }
</style>
