---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found — Parallax Playbook">
  <section class="mx-auto max-w-2xl px-6 sm:px-8 pt-32 pb-24 text-center">
    <p class="micro mb-4">404</p>
    <h1 class="text-4xl font-medium tracking-tight mb-6">This viewpoint shows nothing.</h1>
    <p class="text-muted mb-10">The page you're looking for either moved, or never existed in this universe.</p>
    <div class="flex items-center justify-center gap-6 text-sm font-mono">
      <a href="/" class="hover:text-foreground">← HOME</a>
      <a href="/posts" class="hover:text-foreground">ALL POSTS</a>
    </div>
  </section>
</BaseLayout>
