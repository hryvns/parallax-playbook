---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostArt from "../../components/PostArt.astro";
import { postImage } from "../../lib/postImage";
import { getCollection } from "astro:content";
import { TOPICS } from "../../content.config";

const TOPIC_LABEL: Record<string, string> = {
  quantum: "Quantum",
  consciousness: "Consciousness",
  mathematics: "Mathematics",
};

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title="Posts — Parallax Playbook"
  description="Every post: daily writing on quantum computing, consciousness, and mathematics."
>
  <section class="mx-auto max-w-5xl px-6 sm:px-8 pt-16 pb-10">
    <p class="micro mb-3">The feed</p>
    <h1 class="text-4xl font-medium tracking-tight mb-8">All posts</h1>

    <div class="flex flex-wrap gap-2 font-mono text-small" role="group" aria-label="Filter by topic">
      <button type="button" class="filter-btn is-active" data-filter="all">ALL</button>
      {TOPICS.map((t) => (
        <button type="button" class="filter-btn" data-filter={t}>{TOPIC_LABEL[t].toUpperCase()}</button>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 sm:px-8 pb-24">
    {posts.length === 0 ? (
      <p class="text-muted">Nothing published yet — the first transmission is coming soon.</p>
    ) : (
      <ul id="post-list" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => { const img = postImage(post.id); return (
          <li data-topic={post.data.topic}>
            <a
              href={`/posts/${post.id}`}
              class="group block h-full rounded-xl overflow-hidden border border-hairline bg-surface no-underline transition-colors hover:border-muted/50"
            >
              {img ? (
                <img src={img} alt="" class="aspect-[16/9] w-full object-cover" />
              ) : (
                <PostArt topic={post.data.topic} seed={post.id} class="aspect-[16/9]" />
              )}
              <div class="p-5">
                <div class="flex items-center gap-3 mb-2">
                  <span class="topic-tag">{TOPIC_LABEL[post.data.topic]}</span>
                  {post.data.format === "fact" && <span class="fact-badge">Fact</span>}
                </div>
                <h3 class="text-lg font-medium tracking-tight leading-snug group-hover:text-accent transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-small text-muted leading-relaxed mt-2">
                  {post.data.description}
                </p>
                <time class="block mt-3 text-small text-muted font-mono" datetime={post.data.date.toISOString()}>
                  {dateFmt.format(post.data.date)}
                </time>
              </div>
            </a>
          </li>
        ); })}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .filter-btn {
    border: 1px solid var(--color-hairline);
    border-radius: 999px;
    padding: 0.35em 0.95em;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    background: transparent;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .filter-btn:hover { color: var(--color-foreground); }
  .filter-btn.is-active {
    color: var(--color-foreground);
    border-color: var(--color-foreground);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLLIElement>("#post-list li");
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => b.classList.toggle("is-active", b === btn));
      items.forEach((li) => {
        const show = filter === "all" || li.dataset.topic === filter;
        li.style.display = show ? "" : "none";
      });
    });
  });
</script>
